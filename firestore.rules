rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isValidUser(data) {
      return data.uid is string && data.uid.size() > 0 &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100;
    }

    function isValidStream(data) {
      return data.id is string && data.title is string && data.title.size() > 0 &&
             data.hostUid is string &&
             data.status in ['live', 'ended'];
    }

    function isValidMessage(data) {
      return data.streamId is string && data.uid is string &&
             data.text is string && data.text.size() > 0 && data.text.size() < 500;
    }

    // ===============================================================
    // Match Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if true;
      allow create, update: if isValidUser(request.resource.data);
    }

    match /streams/{streamId} {
      allow read: if true;
      allow create: if isValidStream(request.resource.data);
      allow update: if request.resource.data.hostUid == resource.data.hostUid && isValidStream(request.resource.data);
    }

    match /streams/{streamId}/messages/{messageId} {
      allow read: if true;
      allow create: if isValidMessage(request.resource.data);
    }
  }
}
